{
  "name": "p-gen",
  "version": "1.0.0",
  "description": "P-Gen project with JWT authentication",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "install:all": "npm install",
    "build": "npm run build -w frontend",
    "start": "npm run start -w backend",
    "buildDB": "npm run buildDB -w backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "react",
    "node",
    "jwt",
    "authentication"
  ],
  "author": "",
  "license": "ISC"
}